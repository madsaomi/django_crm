# Django Secret Key (обязательно замените на свой уникальный)
SECRET_KEY=your-secret-key-here

# Debug mode (True для разработки, False для продакшена)
DEBUG=True

# Разрешённые хосты (через запятую)
ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF доверенные origins (через запятую)
CSRF_TRUSTED_ORIGINS=http://localhost:8000
